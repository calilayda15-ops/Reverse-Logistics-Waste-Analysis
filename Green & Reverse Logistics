# --- GLOBAL LOGISTICS DATA ---
product_name = "Deodorant"
total_inventory = 800
damaged_stock = 200
unit_volume_ml = 150
risk_threshold = 100

# 1. NET INVENTORY CALCULATION
# Amacı: Satışa hazır, sağlam ürün miktarını bulmak.
net_inventory = total_inventory - damaged_stock

# 2. TOTAL WASTE VOLUME CALCULATION
# Amacı: Geri dönüşüme gidecek tehlikeli maddelerin toplam kütlesini ölçmek.
total_waste_volume = damaged_stock * unit_volume_ml

# --- REPORTING SECTION ---
print(f"Product: {product_name}")
print(f"Net Inventory (Salable): {net_inventory} units")
print(f"Total Waste Volume to Recycle: {total_waste_volume} ml")

# 3. RISK ANALYSIS (IF-ELSE)
# Amacı: Güvenlik sınırını aşan hasarlı ürünler için otomatik uyarı vermek.
if damaged_stock > risk_threshold:
    print("WARNING: Critical Risk! Please call a licensed hazardous waste vehicle for Reverse Logistics.")
else:
    print("Status: Normal. Standard logistics procedures apply.")
import pandas as pd

# Verilerimizi hazırlayalım
data = {
    "Metric": ["Total Inventory", "Damaged Stock", "Net Inventory", "Total Waste (ml)", "Risk Status"],
    "Value": [800, 200, 600, 30000, "CRITICAL"]
}

# Tabloyu (DataFrame) oluşturalım
df = pd.DataFrame(data)

# Tabloyu ekrana yazdıralım
print("--- LOGISTICS ANALYSIS REPORT ---")
print(df)
